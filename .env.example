# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Local production server (optional; Cloud Run sets PORT automatically)
# PORT=3000

# Cloud Run (recommended: Buildpacks via --source)
# Pass NEXT_PUBLIC_* values at build time so they are embedded during `next build`:
#   gcloud run deploy ondeck-reps \
#     --source . \
#     --region us-central1 \
#     --allow-unauthenticated \
#     --set-build-env-vars NEXT_PUBLIC_SUPABASE_URL=...,NEXT_PUBLIC_SUPABASE_ANON_KEY=...
#
# Buildpacks run `npm run build` then `npm run start` (next start).
# A Dockerfile is also available for manual `docker build` if you prefer.
