# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Local production server (optional; Cloud Run sets PORT automatically)
# PORT=3000

# Docker / Cloud Run: pass NEXT_PUBLIC_* values as build args so they are
# embedded during `next build`, then deploy the image to Cloud Run with:
#   gcloud run deploy live-reps \
#     --source . \
#     --region us-central1 \
#     --allow-unauthenticated \
#     --set-build-env-vars NEXT_PUBLIC_SUPABASE_URL=...,NEXT_PUBLIC_SUPABASE_ANON_KEY=...
